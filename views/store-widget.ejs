<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= storeName %> - محادثة مباشرة</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Cairo', sans-serif; background-color: <%= bg %>; color: white; margin: 0; padding: 0; height: 100vh; display: flex; flex-direction: column; }
    .chat-container { flex: 1; overflow-y: auto; padding: 1rem; display: flex; flex-direction: column; gap: 1rem; scroll-behavior: smooth; }
    .message { max-w: 85%; padding: 0.75rem 1rem; border-radius: 1rem; font-size: 0.95rem; line-height: 1.5; word-wrap: break-word; animation: fadeIn 0.3s ease; }
    .message.user { align-self: flex-start; background-color: <%= color %>; color: #000; border-top-right-radius: 0; }
    .message.bot { align-self: flex-end; background-color: #1a1e36; border border-white/10; border-top-left-radius: 0; }
    .typing-indicator { display: flex; gap: 0.25rem; padding: 0.5rem 1rem; background-color: #1a1e36; border-radius: 1rem; width: fit-content; align-self: flex-end; border-top-left-radius: 0; }
    .dot { width: 6px; height: 6px; background-color: white; border-radius: 50%; opacity: 0.5; animation: blink 1.4s infinite both; }
    .dot:nth-child(1) { animation-delay: 0.2s; }
    .dot:nth-child(2) { animation-delay: 0.4s; }
    .dot:nth-child(3) { animation-delay: 0.6s; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes blink { 0% { opacity: 0.2; transform: scale(0.8); } 20% { opacity: 1; transform: scale(1.2); } 100% { opacity: 0.2; transform: scale(0.8); } }
    
    /* Scrollbar styling */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }
  </style>
</head>
<body>

  <!-- Header -->
  <header class="h-16 shrink-0 flex items-center gap-3 px-4 border-b border-white/10" style="background-color: rgba(255,255,255,0.02);">
    <div class="w-10 h-10 rounded-full flex items-center justify-center text-xl font-bold text-black" style="background-color: <%= color %>;">
      <%= emoji %>
    </div>
    <div>
      <h1 class="font-bold text-sm leading-tight"><%= storeName %></h1>
      <p class="text-xs text-white/50 flex items-center gap-1">
        <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span> متصل الآن
      </p>
    </div>
  </header>

  <!-- Chat Area -->
  <main id="chatBox" class="chat-container">
    <div class="message bot">
      مرحباً بك في <%= storeName %>! كيف يمكنني مساعدتك اليوم؟
    </div>
  </main>

  <!-- Suggestions -->
  <% if (suggestions && suggestions.length > 0) { %>
    <div class="shrink-0 px-4 pb-2 flex gap-2 overflow-x-auto" style="scrollbar-width: none;">
      <% suggestions.forEach(s => { %>
        <button onclick="sendSuggestion('<%= s %>')" class="shrink-0 px-4 py-2 rounded-full border border-white/20 text-sm hover:bg-white/10 transition-colors whitespace-nowrap bg-[#1a1e36]">
          <%= s %>
        </button>
      <% }) %>
    </div>
  <% } %>

  <!-- Input Area -->
  <footer class="shrink-0 p-4 pt-2 border-t border-white/10" style="background-color: rgba(255,255,255,0.02);">
    <form id="chatForm" class="flex items-center gap-2 relative">
      <input 
        id="userInput" 
        type="text" 
        placeholder="اكتب رسالتك هنا..." 
        autocomplete="off"
        class="flex-1 bg-black border border-white/20 rounded-full px-4 py-3 outline-none text-sm text-white focus:border-[<%= color %>] transition-colors"
      />
      <button 
        type="submit" 
        class="w-12 h-12 shrink-0 rounded-full flex items-center justify-center text-black font-bold transition-transform hover:scale-105 active:scale-95" 
        style="background-color: <%= color %>;"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="transform: rotate(180deg); margin-left: -2px;"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
      </button>
    </form>
    <p class="text-center text-[10px] text-white/30 mt-3 flex justify-center items-center gap-1">
      Powered by <span class="font-bold">NovaBOT SaaS</span>
    </p>
  </footer>

  <script>
    const chatBox = document.getElementById('chatBox');
    const form = document.getElementById('chatForm');
    const input = document.getElementById('userInput');
    let messages = [];

    // Unique user ID for this session
    const sessionId = "web_" + Math.random().toString(36).substring(2, 10);

    function scrollToBottom() {
      chatBox.scrollTop = chatBox.scrollHeight;
    }

    function addMessage(text, isUser) {
      const div = document.createElement('div');
      div.className = `message ${isUser ? 'user' : 'bot'}`;
      // Replace newlines with <br> and format bold markdown
      let formattedText = text.replace(/\n/g, '<br/>').replace(/\*(.*?)\*/g, '<b>$1</b>');
      div.innerHTML = formattedText;
      chatBox.appendChild(div);
      scrollToBottom();
    }

    function showTyping() {
      const div = document.createElement('div');
      div.id = 'typingIndicator';
      div.className = 'typing-indicator';
      div.innerHTML = '<div class="dot"></div><div class="dot"></div><div class="dot"></div>';
      chatBox.appendChild(div);
      scrollToBottom();
    }

    function hideTyping() {
      const indicator = document.getElementById('typingIndicator');
      if (indicator) indicator.remove();
    }

    async function sendMessage(text) {
      if (!text.trim()) return;
      
      addMessage(text, true);
      messages.push({ role: "user", content: text });
      // Keep last 12 messages
      if (messages.length > 12) messages = messages.slice(-12);

      showTyping();

      try {
        const response = await fetch('/store/<%= slug %>/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages, phone: sessionId })
        });
        
        hideTyping();
        
        if (!response.ok) throw new Error('Network response was not ok');
        
        const data = await response.json();
        const reply = data.reply;
        
        messages.push({ role: "assistant", content: reply });
        addMessage(reply, false);
      } catch (err) {
        hideTyping();
        addMessage("عذراً، حدث خطأ في الاتصال. يرجى المحاولة مرة أخرى.", false);
        messages.pop(); // remove the user message if it failed
      }
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const text = input.value;
      input.value = '';
      sendMessage(text);
    });

    window.sendSuggestion = function(text) {
      sendMessage(text);
    };
  </script>
</body>
</html>
