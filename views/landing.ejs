<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>NovaBOT — بوت واتساب ذكي لمتجرك</title>
<meta name="description" content="حوّل رقم واتساب متجرك إلى بوت ذكي يرد على زبائنك 24/7 بالدارجة الجزائرية"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0f1225;--bg-s:#13162b;--bg-t:#1a1e36;
  --text:#f1f5f9;--text-m:#94a3b8;--text-d:#64748b;
  --accent:#5c62fa;--accent-l:#818cf8;--accent-d:#4a4fdd;
  --border:rgba(255,255,255,0.06);--border-l:rgba(255,255,255,0.12);
  --green:#22c55e;--radius:12px;
}
html{scroll-behavior:smooth}
body{font-family:'Inter','Cairo',sans-serif;background:var(--bg);color:var(--text);line-height:1.6;overflow-x:hidden;-webkit-font-smoothing:antialiased}

/* Utility */
.container{max-width:1120px;margin:0 auto;padding:0 24px;position:relative;z-index:1}
.badge{display:inline-flex;align-items:center;gap:6px;padding:5px 14px;border:1px solid var(--border);border-radius:100px;font-size:13px;color:var(--text-m);background:var(--bg-s);font-weight:500}
.badge-dot{width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:0 0 8px var(--green);animation:pulse 2s infinite}
.btn{display:inline-flex;align-items:center;gap:8px;padding:10px 22px;border-radius:var(--radius);font-size:14px;font-weight:600;font-family:inherit;cursor:pointer;transition:all .2s;text-decoration:none;border:none}
.btn-p{background:var(--accent);color:#fff;box-shadow:0 4px 15px rgba(92,98,250,0.3)}
.btn-p:hover{background:var(--accent-d);transform:translateY(-1px);box-shadow:0 8px 25px rgba(92,98,250,0.4)}
.btn-s{background:var(--bg-t);color:var(--text);border:1px solid var(--border-l)}
.btn-s:hover{border-color:var(--accent);background:rgba(92,98,250,0.08)}
.btn-lg{padding:14px 28px;font-size:15px;border-radius:14px}

/* Header */
header{position:fixed;top:0;left:0;right:0;z-index:100;height:64px;display:flex;align-items:center;background:rgba(9,9,11,.8);backdrop-filter:blur(16px);border-bottom:1px solid var(--border)}
.h-inner{max-width:1120px;margin:0 auto;width:100%;padding:0 24px;display:flex;align-items:center;justify-content:space-between}
.logo{display:flex;align-items:center;gap:10px;text-decoration:none}
.logo-i{width:34px;height:34px;background:var(--accent);border-radius:10px;display:grid;place-items:center;font-weight:800;font-size:14px;color:#fff;box-shadow:0 4px 12px rgba(92,98,250,0.35)}
.logo-t{font-weight:700;font-size:16px;color:var(--text);letter-spacing:-.3px}
nav{display:flex;align-items:center;gap:4px}
nav a.nl{color:var(--text-m);text-decoration:none;font-size:14px;font-weight:500;padding:6px 12px;border-radius:8px;transition:color .2s}
nav a.nl:hover{color:var(--text)}

/* Hero */
.hero{padding:140px 0 80px;text-align:center;position:relative;overflow:hidden}
.hero-glow{position:absolute;top:-100px;left:50%;transform:translateX(-50%);width:900px;height:600px;background:radial-gradient(ellipse,rgba(92,98,250,0.15),transparent 70%);pointer-events:none}
.hero h1{font-size:clamp(36px,5.5vw,64px);font-weight:800;line-height:1.1;letter-spacing:-2px;margin:24px 0}
.hero h1 span{background:linear-gradient(135deg,var(--accent-l),#c084fc);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero-sub{font-size:clamp(16px,2vw,19px);color:var(--text-m);max-width:540px;margin:0 auto 36px;line-height:1.7;font-weight:400}
.hero-cta{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}

/* Logos */
.logos{padding:48px 0;border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.logos p{text-align:center;font-size:13px;color:var(--text-d);font-weight:500;letter-spacing:1px;text-transform:uppercase;margin-bottom:24px}
.logos-row{display:flex;justify-content:center;gap:40px;flex-wrap:wrap;align-items:center;opacity:.5}
.logos-row span{font-size:18px;font-weight:700;color:var(--text-m);letter-spacing:1px}

/* Section */
section{padding:80px 0}
.s-label{font-size:13px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--accent-l);margin-bottom:12px}
.s-title{font-size:clamp(26px,3.5vw,42px);font-weight:800;letter-spacing:-1px;margin-bottom:12px;line-height:1.2}
.s-sub{font-size:16px;color:var(--text-m);max-width:500px;line-height:1.7}
.s-head{margin-bottom:48px}
.s-head-c{text-align:center}.s-head-c .s-sub{margin:0 auto}

/* Steps */
.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:16px;overflow:hidden}
.step{background:var(--bg);padding:32px;transition:background .3s}
.step:hover{background:var(--bg-s)}
.step-n{font-size:13px;font-weight:700;color:var(--accent-l);margin-bottom:16px}
.step h3{font-size:17px;font-weight:700;margin-bottom:8px}
.step p{font-size:14px;color:var(--text-m);line-height:1.7}

/* Features */
.feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.feat{background:var(--bg-s);border:1px solid var(--border);border-radius:16px;padding:28px;transition:all .25s}
.feat:hover{border-color:rgba(92,98,250,0.4);transform:translateY(-2px);box-shadow:0 8px 30px rgba(92,98,250,0.1)}
.feat-icon{width:44px;height:44px;border-radius:12px;background:rgba(92,98,250,0.12);border:1px solid rgba(92,98,250,0.2);display:grid;place-items:center;font-size:20px;margin-bottom:16px}
.feat h3{font-size:16px;font-weight:700;margin-bottom:6px}
.feat p{font-size:14px;color:var(--text-m);line-height:1.7}

/* Pricing */
.price-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;max-width:700px;margin:0 auto}
.plan{background:var(--bg-s);border:1px solid var(--border-l);border-radius:20px;padding:32px;position:relative}
.plan.pop{border-color:var(--accent);box-shadow:0 0 0 1px var(--accent),0 8px 40px rgba(92,98,250,0.15)}
.plan-tag{position:absolute;top:-11px;right:24px;background:var(--accent);color:#fff;font-size:11px;font-weight:700;padding:3px 12px;border-radius:100px}
.plan-name{font-size:13px;font-weight:600;color:var(--text-m);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:12px}
.plan-price{font-size:42px;font-weight:800;letter-spacing:-2px;margin-bottom:4px}
.plan-price small{font-size:15px;color:var(--text-m);font-weight:400}
.plan-desc{font-size:14px;color:var(--text-d);margin-bottom:24px;padding-bottom:24px;border-bottom:1px solid var(--border)}
.plan ul{list-style:none;margin-bottom:28px}
.plan li{display:flex;align-items:center;gap:10px;font-size:14px;padding:6px 0;color:var(--text-m)}
.plan li::before{content:'✓';width:20px;height:20px;border-radius:50%;background:rgba(34,197,94,.1);display:grid;place-items:center;font-size:11px;color:var(--green);flex-shrink:0}
.plan .btn{width:100%;justify-content:center}

/* Auth */
.auth-s{padding:80px 0;position:relative}
.auth-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;max-width:700px;margin:0 auto}
.auth-c{background:var(--bg-s);border:1px solid var(--border-l);border-radius:20px;padding:32px}
.auth-c.hl{border-color:var(--accent);box-shadow:0 0 0 1px rgba(92,98,250,0.5),0 8px 40px rgba(92,98,250,0.1)}
.auth-t{font-size:20px;font-weight:700;margin-bottom:20px}
.auth-i{width:100%;background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:12px 14px;color:var(--text);font-family:inherit;font-size:14px;margin-bottom:12px;outline:none;transition:border-color .2s}
.auth-i:focus{border-color:var(--accent)}
.auth-err{color:#f87171;font-size:13px;background:rgba(248,113,113,.08);padding:8px 12px;border-radius:8px;margin-bottom:12px}
.auth-btn{width:100%;justify-content:center;margin-top:4px}

/* Chat Demo */
.demo-wrap{max-width:360px;margin:48px auto 0;animation:float 5s ease-in-out infinite}
.demo{background:var(--bg-s);border:1px solid var(--border-l);border-radius:20px;padding:16px;box-shadow:0 20px 60px rgba(0,0,0,.5),0 0 0 1px rgba(92,98,250,0.1)}
.demo-h{display:flex;align-items:center;gap:10px;padding-bottom:12px;border-bottom:1px solid var(--border);margin-bottom:12px}
.demo-av{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,#25d366,#128c7e);display:grid;place-items:center;font-size:15px}
.demo-name{font-size:13px;font-weight:600}
.demo-st{font-size:11px;color:var(--green)}
.msg{margin-bottom:8px}
.msg-b{padding:8px 12px;font-size:13px;line-height:1.6;max-width:85%;border-radius:12px}
.msg.bot .msg-b{background:var(--bg-t);border-radius:12px 12px 12px 4px;color:var(--text-m)}
.msg.usr{display:flex;justify-content:flex-start}
.msg.usr .msg-b{background:rgba(92,98,250,0.15);border:1px solid rgba(92,98,250,0.25);border-radius:12px 12px 4px 12px;color:var(--accent-l);margin-right:auto}

/* Footer */
footer{border-top:1px solid var(--border);padding:32px 24px;text-align:center;background:var(--bg-s)}
footer p{font-size:13px;color:var(--text-d)}

/* Animations */
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.reveal{opacity:0;transform:translateY(20px);transition:opacity .6s,transform .6s}.reveal.v{opacity:1;transform:none}

/* Responsive */
@media(max-width:768px){
  .steps,.feat-grid{grid-template-columns:1fr}
  .steps{background:none;border:none;gap:12px}
  .step{border:1px solid var(--border);border-radius:12px}
  .price-grid,.auth-grid{grid-template-columns:1fr}
  nav .nl{display:none}
  .demo-wrap{max-width:280px}
  .logos-row{gap:24px}
}
</style>
</head>
<body>

<header>
  <div class="h-inner">
    <a href="/" class="logo"><div class="logo-i">N</div><span class="logo-t">NovaBOT</span></a>
    <nav>
      <a href="#how" class="nl">كيف يعمل</a>
      <a href="#features" class="nl">المميزات</a>
      <a href="#pricing" class="nl">الأسعار</a>
      <a href="#auth" class="btn btn-s" style="font-size:13px;padding:7px 16px">دخول</a>
      <a href="#auth" class="btn btn-p" style="font-size:13px;padding:7px 16px">ابدأ مجاناً</a>
    </nav>
  </div>
</header>

<!-- HERO -->
<section class="hero">
  <div class="hero-glow"></div>
  <div class="container">
    <div class="badge"><span class="badge-dot"></span>مدعوم بذكاء اصطناعي — ردود في أقل من 3 ثوانٍ</div>
    <h1>بوت واتساب ذكي<br/><span>لمتجرك الجزائري</span></h1>
    <p class="hero-sub">اربط رقم واتساب متجرك ببوت يرد على الزبائن، يشرح المنتجات، ويحفظ الطلبات تلقائياً — 24/7 بدون تدخل منك.</p>
    <div class="hero-cta">
      <a href="#auth" class="btn btn-p btn-lg">ابدأ مجاناً <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
      <a href="#how" class="btn btn-s btn-lg">كيف يعمل؟</a>
    </div>

    <div class="demo-wrap">
      <div class="demo">
        <div class="demo-h">
          <div class="demo-av">🛍</div>
          <div><div class="demo-name">متجر الأناقة</div><div class="demo-st">● متصل</div></div>
        </div>
        <div class="msg bot"><div class="msg-b">مرحباً! 👋 كيف نقدر نساعدك؟</div></div>
        <div class="msg usr"><div class="msg-b">واش عندكم قمصان مقاس L؟</div></div>
        <div class="msg bot"><div class="msg-b">نعم كاين 3 موديلات 🎉<br/>من 2500 إلى 4500 دج</div></div>
      </div>
    </div>
  </div>
</section>

<!-- LOGOS -->
<div class="logos">
  <div class="container">
    <p>+500 تاجر يستخدمون NovaBOT</p>
    <div class="logos-row">
      <span>WhatsApp</span><span>Groq AI</span><span>Google Sheets</span><span>UltraMsg</span>
    </div>
  </div>
</div>

<!-- HOW -->
<section id="how">
  <div class="container">
    <div class="s-head s-head-c reveal">
      <div class="s-label">كيف يعمل</div>
      <h2 class="s-title">3 خطوات فقط</h2>
      <p class="s-sub">بدون كود، بدون إعدادات معقدة.</p>
    </div>
    <div class="steps reveal">
      <div class="step"><div class="step-n">01</div><h3>اكتب تعليمات متجرك</h3><p>أدخل المنتجات، الأسعار، وطريقة التوصيل. البوت يفهم الدارجة 🇩🇿</p></div>
      <div class="step"><div class="step-n">02</div><h3>امسح الـ QR</h3><p>افتح واتساب → الأجهزة المرتبطة → امسح الكود ورقمك يصبح بوت.</p></div>
      <div class="step"><div class="step-n">03</div><h3>ابدأ البيع</h3><p>البوت يرد، يقنع، ويحفظ الطلبات. وأنت تتابع الإحصائيات.</p></div>
    </div>
  </div>
</section>

<!-- FEATURES -->
<section id="features">
  <div class="container">
    <div class="s-head s-head-c reveal">
      <div class="s-label">المميزات</div>
      <h2 class="s-title">كل ما يحتاجه متجرك</h2>
      <p class="s-sub">تقنية متقدمة في واجهة بسيطة.</p>
    </div>
    <div class="feat-grid">
      <div class="feat reveal"><div class="feat-icon">⚡</div><h3>رد فوري</h3><p>البوت يرد في أقل من 3 ثوانٍ — حتى الساعة 3 صباحاً.</p></div>
      <div class="feat reveal"><div class="feat-icon">🧠</div><h3>ذكاء اصطناعي</h3><p>يفهم الدارجة، يقنع الزبون، ويجيب بدقة على كل الأسئلة.</p></div>
      <div class="feat reveal"><div class="feat-icon">📊</div><h3>إحصائيات مباشرة</h3><p>تتبع المحادثات والطلبات والأسئلة المتكررة.</p></div>
      <div class="feat reveal"><div class="feat-icon">🎙️</div><h3>فهم الصوتيات</h3><p>البوت يفهم الرسائل الصوتية ويحولها لنص ثم يرد عليها.</p></div>
      <div class="feat reveal"><div class="feat-icon">📋</div><h3>حفظ الطلبات</h3><p>الطلبات تُستخرج تلقائياً وتُحفظ في Google Sheets.</p></div>
      <div class="feat reveal"><div class="feat-icon">🎨</div><h3>تخصيص كامل</h3><p>اسم البوت، لونه، أسلوبه — كل شيء يعكس هوية متجرك.</p></div>
    </div>
  </div>
</section>

<!-- PRICING -->
<section id="pricing" style="background:var(--bg-s);border-top:1px solid var(--border);border-bottom:1px solid var(--border)">
  <div class="container">
    <div class="s-head s-head-c reveal">
      <div class="s-label">الأسعار</div>
      <h2 class="s-title">خطط بسيطة وشفافة</h2>
      <p class="s-sub">ابدأ مجاناً، ارقِّ عند الحاجة.</p>
    </div>
    <div class="price-grid">
      <div class="plan reveal">
        <div class="plan-name">مجاني</div>
        <div class="plan-price">0 <small>دج/شهر</small></div>
        <p class="plan-desc">للتجار الجدد</p>
        <ul>
          <li>متجر واحد</li>
          <li>100 رسالة/يوم</li>
          <li>إحصائيات أساسية</li>
        </ul>
        <a href="#auth" class="btn btn-s">ابدأ مجاناً</a>
      </div>
      <div class="plan pop reveal">
        <div class="plan-tag">الأكثر شعبية</div>
        <div class="plan-name">احترافي</div>
        <div class="plan-price">1500 <small>دج/شهر</small></div>
        <p class="plan-desc">للتجار الجادين</p>
        <ul>
          <li>متاجر غير محدودة</li>
          <li>رسائل غير محدودة</li>
          <li>إحصائيات متقدمة</li>
          <li>حفظ الطلبات في Sheets</li>
          <li>أولوية الدعم</li>
        </ul>
        <a href="#auth" class="btn btn-p">ابدأ التجربة</a>
      </div>
    </div>
  </div>
</section>

<!-- AUTH -->
<section id="auth" class="auth-s">
  <div class="container">
    <div class="s-head s-head-c reveal">
      <div class="s-label">ابدأ الآن</div>
      <h2 class="s-title">سجّل في ثوانٍ</h2>
    </div>
    <div class="auth-grid">
      <div class="auth-c reveal" id="login">
        <h2 class="auth-t">تسجيل الدخول</h2>
        <% if (locals.loginError) { %><div class="auth-err"><%= loginError %></div><% } %>
        <form method="post" action="/auth/login">
          <input name="email" type="email" required placeholder="البريد الإلكتروني" class="auth-i"/>
          <input name="password" type="password" required placeholder="كلمة المرور" class="auth-i"/>
          <button type="submit" class="btn btn-s auth-btn">تسجيل الدخول</button>
        </form>
      </div>
      <div class="auth-c hl reveal" id="signup">
        <h2 class="auth-t" style="color:var(--accent-l)">إنشاء حساب جديد</h2>
        <% if (locals.signupError) { %><div class="auth-err"><%= signupError %></div><% } %>
        <form method="post" action="/auth/signup">
          <input name="email" type="email" required placeholder="البريد الإلكتروني" class="auth-i"/>
          <input name="password" type="password" minlength="6" required placeholder="كلمة المرور (6 أحرف على الأقل)" class="auth-i"/>
          <button type="submit" class="btn btn-p auth-btn">ابدأ مجاناً الآن</button>
        </form>
      </div>
    </div>
  </div>
</section>

<footer>
  <p>© 2026 NovaBOT — بوت واتساب ذكي للمتاجر الجزائرية</p>
</footer>

<script>
const obs=new IntersectionObserver(e=>{e.forEach(el=>{if(el.isIntersecting){el.target.classList.add('v');obs.unobserve(el.target)}})},{threshold:.1});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));
</script>
</body>
</html>